<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DevLog</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-black pb-5">

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="text-primary">Latest Articles</h1>
        <a href="/posts/new" class="btn btn-success shadow-sm">Create New Post</a>
    </div>

    <% if (posts.length === 0) { %>
        <div class="alert alert-info text-center" role="alert">
            No posts found. Be the first to create one!
        </div>
    <% } %>

    <div class="row">
        <% posts.forEach(post => { %>
            <div class="col-md-8 mx-auto mb-4">
                <div class="card shadow-sm border-0 bg-dark">
                    <div class="card-body">
                        <h2 class="card-title"><%= post.title %></h2>
                        <h6 class="card-subtitle mb-3 text-muted">
                            By <%= post.author %> on <%= post.date %>
                        </h6>
                        <p class="card-text" style="white-space: pre-wrap;"><%= post.content.length > 150 ? post.content.substring(0, 150) + '...' : post.content %></p>
                        
                        <div class="d-flex justify-content-end mt-4">
                            <a href="/posts/<%= post.id %>" class="btn btn-primary">Read More</a>
                        </div>
                    </div>
                </div>
            </div>
        <% }) %>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
