<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= post.title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-black pb-5">

<div class="container mt-5">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <a href="/" class="btn btn-outline-secondary mb-4">&larr; Back to Feed</a>

            <div class="card shadow-sm border-0 bg-dark">
                <div class="card-body p-5">
                    <h1 class="card-title text-primary fw-bold mb-3"><%= post.title %></h1>
                    <h6 class="card-subtitle mb-4 text-muted border-bottom pb-3">
                        By <span class="fw-semibold"><%= post.author %></span> on <%= post.date %>
                    </h6>
                    
                    <div class="card-text fs-5" style="white-space: pre-wrap; line-height: 1.8;"><%= post.content %></div>
                    
                    <hr class="mt-5 mb-4">
                    
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="text-muted small">Post ID: <%= post.id %></span>
                        
                        <div class="d-flex gap-2">
                            <a href="/posts/<%= post.id %>/edit" class="btn btn-warning shadow-sm">Edit Post</a>
                            
                            <form action="/posts/<%= post.id %>?_method=DELETE" method="POST" onsubmit="return confirm('Are you sure you want to delete this post? This action cannot be undone.');">
                                <button type="submit" class="btn btn-danger shadow-sm">Delete</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
