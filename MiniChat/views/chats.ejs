<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chats</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <nav>
        <a href="/"> Home </a>
        <a href="/chats"  class="current"> Chats </a>
        <a href="/chats/new"> New Chat </a>
    </nav>
    <% for(let i = allChats.length-1; 0<=i; i-=1) { %>
        <div class="container">
            <h4 class="from"> <%= allChats[i].from %> said:</h4>
            <p class="message"> <%= allChats[i].message %> </p>
            <h4 class="to"> to <%= allChats[i].to %> </h4>
            <p class="date"> at <%= allChats[i].date %> </p>
        </div>
    <% } %>
</body>
</html>